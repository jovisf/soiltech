generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Farm {
  id        String   @id @default(uuid())
  name      String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  pivots    Pivot[]

  @@map("farms")
}

model Pivot {
  id         String   @id @default(uuid())
  name       String
  latitude   Float
  longitude  Float
  status     Json
  bladeAt100 Float    @map("blade_at_100")
  createdAt  DateTime @default(now()) @map("created_at")
  farmId     String   @map("farm_id")
  updatedAt  DateTime @updatedAt @map("updated_at")
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  states     State[]

  @@index([farmId])
  @@map("pivots")
}

model State {
  id           String   @id @default(uuid())
  timestamp    DateTime
  direction    String
  isIrrigating Boolean  @map("is_irrigating")
  isOn         Boolean  @map("is_on")
  pivotId      String   @map("pivot_id")
  cycles       Cycle[]
  pivot        Pivot    @relation(fields: [pivotId], references: [id], onDelete: Cascade)

  @@index([pivotId])
  @@map("states")
}

model Cycle {
  id            String   @id @default(uuid())
  timestamp     DateTime
  angle         Float
  percentimeter Float
  stateId       String   @map("state_id")
  state         State    @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([stateId])
  @@map("cycles")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}
